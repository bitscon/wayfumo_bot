# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# ---- Mode / behavior ----
BOT_MODE=clickbait            # clickbait (Printful) | roast (legacy Reddit)
DRY_RUN=true                  # true = build & print, never post to X
POST_TO_X=true
POST_TO_TIKTOK=false
PRODUCT_STRATEGY=random       # random | rotate (day-of-year based)
VOICE_MODE=blend              # blend (rotate) | roast | hype

# ---- Printful ----
# Token: Printful dashboard -> Settings -> Developers -> API tokens
PRINTFUL_TOKEN=
PRINTFUL_STORE_ID=            # only needed for account-level tokens
STORE_BASE_URL=https://yourstore.printful.me
UTM_CAMPAIGN=clickbait

# ---- LLM provider ----
LLM_PROVIDER=ollama           # ollama | openrouter
OLLAMA_URL=http://llm.workshop.home/api/generate
OLLAMA_MODEL=llama3.2:latest
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# ---- X / Twitter (OAuth 1.0a) ----
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ---- Reddit (legacy roast mode only) ----
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=WAYFUMO Bot by /u/yourusername

# ---- TikTok (still stubbed) ----
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ACCESS_SECRET=
